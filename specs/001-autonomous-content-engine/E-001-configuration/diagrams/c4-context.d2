# C4 Context Diagram — E-001 Content Engine Configuration
# SEO Toolkit (PROD-001)

direction: right

title: {
  label: "C4 Context — Content Engine Configuration"
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

# === People ===

site_owner: "Site Owner\n[Person]" {
  shape: person
  style.fill: "#08427B"
  style.font-color: "#ffffff"
}

# === System Boundary ===

seo_toolkit: "SEO Toolkit CLI\n[Software System]\n\nRegisters websites, detects CMS\nplatform, crawls site structure,\nand manages content engine\nconfiguration." {
  shape: rectangle
  style.fill: "#1168BD"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

# === External Systems ===

target_website: "Target Website\n[External System]\n\nThe website being registered\nand analysed for CMS type,\nlanguage, and content." {
  shape: rectangle
  style.fill: "#999999"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

wordpress_api: "WordPress REST API\n[External System]\n\nWP REST API at /wp-json/wp/v2/\nand login page at /wp-login.php.\nUsed for CMS detection and\ncontent publishing." {
  shape: rectangle
  style.fill: "#999999"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

shopify_cdn: "Shopify Platform\n[External System]\n\ncdn.shopify.com assets and\nShopify.theme JS markers.\nUsed for CMS detection and\ncontent publishing." {
  shape: rectangle
  style.fill: "#999999"
  style.font-color: "#ffffff"
  style.border-radius: 8
}

# === Relationships ===

site_owner -> seo_toolkit: "Registers website,\nconfigures content engine" {
  style.stroke: "#08427B"
}

seo_toolkit -> target_website: "Fetches HTML, sitemap.xml,\nlanguage tags" {
  style.stroke: "#707070"
}

seo_toolkit -> wordpress_api: "Probes /wp-json/wp/v2/\nand /wp-login.php\n[HTTPS]" {
  style.stroke: "#707070"
}

seo_toolkit -> shopify_cdn: "Checks for cdn.shopify.com\nand Shopify.theme markers\n[HTTPS]" {
  style.stroke: "#707070"
}
