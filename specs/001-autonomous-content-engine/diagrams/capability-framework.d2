monitor: {
  label: "5. Monitor & Refresh"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"

  perf: {
    label: "Performance"
    rank: "5.1 Rank Tracking [AUTO][TS]"
    ai-vis: "5.2 AI Visibility [AUTO][DF]"
