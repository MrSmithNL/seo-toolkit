publish: {
  label: "4. Publish"
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"

  publishing: {
    label: "Content Publishing"
    wordpress: "4.1 WordPress [AUTO][TS]"
    shopify: "4.2 Shopify [AUTO][DF]"
