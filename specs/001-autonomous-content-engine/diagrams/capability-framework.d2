# === PIPELINE FLOW ===

research -> create: "briefs"
create -> optimise: "drafts"
optimise -> publish: "optimised"
publish -> measure: "live pages"
measure -> research: "re-optimise\ntrigger" { style.stroke-dash: 5 }
measure -> dashboard: "data"

