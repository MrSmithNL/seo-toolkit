configure -> research: feeds
research -> generate: informs
generate -> publish: outputs
publish -> monitor: tracks
monitor -> generate: refresh {style.stroke-dash: 3}

cross-cutting: {
  label: "Cross-Cutting"
  style.fill: "#ECEFF1"
  multi-model: "X.1 Multi-Model AI [DF]"
