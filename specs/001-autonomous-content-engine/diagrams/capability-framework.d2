  optimisation: {
    label: "Content Optimisation"
    seo-score: "3.7.1 SEO Score [AUTO][TS]"
    aiso-score: "3.7.2 AISO 36-Factor [AUTO][IN]" {
      style.fill: "#FFF3E0"
    }
